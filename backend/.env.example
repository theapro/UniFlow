# MySQL connection string for Prisma
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/uniflow"

# Server
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET="change_me"
JWT_EXPIRES_IN="7d"

# Google Sign-In (ID token verification)
# Create OAuth Client ID in Google Cloud Console.
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"

# Email (Resend)
RESEND_API_KEY="re_XXXXXXXXXXXXXXXXXXXXXXXX"
# Format can be either:
# - "noreply@yourdomain.com" (must be verified in Resend)
# - "UniFlow <noreply@yourdomain.com>"
RESEND_FROM_EMAIL="UniFlow <noreply@yourdomain.com>"

# Where users will login (used inside email)
USER_APP_URL="http://localhost:3002/login"

# --- Google Sheets (Service Account) ---
# Shared credentials for all Google Spreadsheets UniFlow connects to.
GOOGLE_SHEETS_CLIENT_EMAIL="your-service-account@your-project.iam.gserviceaccount.com"

# Recommended: store the private key as BASE64 (avoids newline issues)
# Example (PowerShell): [Convert]::ToBase64String([IO.File]::ReadAllBytes('key.json'))
GOOGLE_SHEETS_PRIVATE_KEY_BASE64=""

# Alternative: paste the private key here and replace newlines with \n
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Students Spreadsheet (tabs = groups) ---
GOOGLE_SHEETS_STUDENTS_ENABLED="false"
GOOGLE_SHEETS_STUDENTS_SPREADSHEET_ID="1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Optional tab filtering (treat only matching tabs as "groups")
# Example allow regex: ^\\d{2,4}.*$  (tabs starting with year)
GOOGLE_SHEETS_STUDENTS_GROUP_TABS_ALLOW_REGEX=""
# Example deny regex: ^(?:Sheet\\d+|Summary|Config)$
GOOGLE_SHEETS_STUDENTS_GROUP_TABS_DENY_REGEX=""

# Optional: run background sync in the API process (dev) or as a separate worker (prod)
GOOGLE_SHEETS_STUDENTS_WORKER_ENABLED="false"
GOOGLE_SHEETS_STUDENTS_WORKER_INTERVAL_MS="60000"

# Optional: enable DB -> Sheets writes (outbox processing)
GOOGLE_SHEETS_STUDENTS_DB_TO_SHEETS_ENABLED="true"

# Optional: detect deletes (missing rows) when pulling Sheets -> DB
GOOGLE_SHEETS_STUDENTS_DETECT_DELETES="false"

# Optional: secure webhook trigger (Apps Script onEdit -> POST /webhooks/students-sheets)
GOOGLE_SHEETS_STUDENTS_WEBHOOK_SECRET=""

# --- Teachers Spreadsheet (TeachersWithSubjects; tabs = subjects) ---
GOOGLE_SHEETS_TEACHERS_ENABLED="false"
GOOGLE_SHEETS_TEACHERS_SPREADSHEET_ID="1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Optional: run background sync in the API process (dev) or as a separate worker (prod)
GOOGLE_SHEETS_TEACHERS_WORKER_ENABLED="false"
GOOGLE_SHEETS_TEACHERS_WORKER_INTERVAL_MS="60000"

# Optional: enable DB -> Sheets writes
GOOGLE_SHEETS_TEACHERS_DB_TO_SHEETS_ENABLED="true"

# Optional tab filtering (treat only matching tabs as "subjects")
GOOGLE_SHEETS_TEACHERS_SUBJECT_TABS_ALLOW_REGEX=""
GOOGLE_SHEETS_TEACHERS_SUBJECT_TABS_DENY_REGEX=""

# --- Attendance Spreadsheet (tabs = GROUP_SUBJECT) ---
GOOGLE_SHEETS_ATTENDANCE_ENABLED="false"
GOOGLE_SHEETS_ATTENDANCE_SPREADSHEET_ID="1hDwHHuv7_6z62fpralx57olOf_xTYMsc_Pjbxx_Ejd0"

# --- Grades Spreadsheet (Baholash; tabs = GROUP_SUBJECT) ---
GOOGLE_SHEETS_GRADES_ENABLED="false"
GOOGLE_SHEETS_GRADES_SPREADSHEET_ID="1lG9yNJCiIwwTDc6PVO1zvv-0iVrCxU063MvPFX9Ksv8"

# Optional tab filtering (treat only matching tabs as grades tabs)
GOOGLE_SHEETS_GRADES_TABS_ALLOW_REGEX=""
GOOGLE_SHEETS_GRADES_TABS_DENY_REGEX=""

# Optional: run background sync in the API process (dev) or as a separate worker (prod)
GOOGLE_SHEETS_ATTENDANCE_WORKER_ENABLED="false"
GOOGLE_SHEETS_ATTENDANCE_WORKER_INTERVAL_MS="60000"

# Optional: enable DB -> Sheets writes (roster columns A-C only)
GOOGLE_SHEETS_ATTENDANCE_DB_TO_SHEETS_ENABLED="true"

# Optional: secure webhook trigger (Apps Script -> POST /webhooks/attendance-sheets)
GOOGLE_SHEETS_ATTENDANCE_WEBHOOK_SECRET=""

# Optional tab filtering (treat only matching tabs as attendance tabs)
GOOGLE_SHEETS_ATTENDANCE_TABS_ALLOW_REGEX=""
GOOGLE_SHEETS_ATTENDANCE_TABS_DENY_REGEX=""

# Date parsing format for attendance header cells (D+). Supported: MM/DD or DD/MM
GOOGLE_SHEETS_ATTENDANCE_DATE_FORMAT="MM/DD"
