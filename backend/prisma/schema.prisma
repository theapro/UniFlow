generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Department {
  id        String    @id @default(uuid()) @db.Char(36)
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  teachers  Teacher[]

  @@map("Department")
}

model Room {
  id              String          @id @default(uuid()) @db.Char(36)
  name            String          @unique
  capacity        Int?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  scheduleEntries ScheduleEntry[]

  schedules Schedule[]

  @@map("Room")
}

model TimeSlot {
  id              String          @id @default(uuid()) @db.Char(36)
  slotNumber      Int             @unique
  startTime       DateTime        @db.Time(0)
  endTime         DateTime        @db.Time(0)
  isBreak         Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  scheduleEntries ScheduleEntry[]

  schedules Schedule[]

  @@map("TimeSlot")
}

model Group {
  id              String          @id @default(uuid()) @db.Char(36)
  name            String          @unique
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  cohortId        String?         @db.Char(36)
  cohort          Cohort?         @relation(fields: [cohortId], references: [id])
  parentGroupId   String?         @db.Char(36)
  parentGroup     ParentGroup?    @relation(fields: [parentGroupId], references: [id], onDelete: SetNull)
  lessons         Lesson[]
  scheduleEntries ScheduleEntry[]
  studentGroups   StudentGroup[]
  gradeBooks      GradeBook[]

  schedules Schedule[]

  @@index([cohortId])
  @@index([parentGroupId])
  @@map("Group")
}

model ParentGroup {
  id        String   @id @default(uuid()) @db.Char(36)
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groups Group[]
  subjects Subject[]

  @@map("ParentGroup")
}

model Cohort {
  id        String   @id @default(uuid()) @db.Char(36)
  code      String   @unique
  sortOrder Int      @default(0)
  year      Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  groups    Group[]
  subjects  Subject[]

  @@index([sortOrder])

  @@map("Cohort")
}

model Student {
  id            String        @id @default(uuid()) @db.Char(36)
  fullName      String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  email         String?
  note          String?
  parentIds     Json?
  phone         String?
  status        StudentStatus @default(ACTIVE)
  studentNumber String?       @unique
  studentGroups StudentGroup[]
  attendance    Attendance[]
  user          User?
  gradeRecords   GradeRecord[]

  @@map("Student")
}

model StudentGroup {
  id        String   @id @default(uuid()) @db.Char(36)
  studentId String   @db.Char(36)
  groupId   String   @db.Char(36)
  joinedAt  DateTime? @db.Date
  leftAt    DateTime? @db.Date
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  group   Group   @relation(fields: [groupId], references: [id], onDelete: Restrict)

  @@unique([studentId, groupId])
  @@index([studentId])
  @@index([groupId])
  @@map("StudentGroup")
}

model StudentsSheetsConflict {
  id            String                            @id @default(uuid()) @db.Char(36)
  spreadsheetId String
  sheetTitle    String?
  rowNumber     Int?
  studentId     String?                           @db.Char(36)
  status        StudentsSheetsConflictStatus      @default(OPEN)
  resolution    StudentsSheetsConflictResolution?
  message       String?
  sheetPayload  Json?
  dbPayload     Json?
  baseHash      String?
  detectedAt    DateTime                          @default(now())
  resolvedAt    DateTime?
  createdAt     DateTime                          @default(now())
  updatedAt     DateTime                          @updatedAt

  @@unique([spreadsheetId, studentId])
  @@index([spreadsheetId, status, detectedAt])
  @@index([studentId])
  @@map("StudentsSheetsConflict")
}

model Teacher {
  id              String          @id @default(uuid()) @db.Char(36)
  fullName        String
  staffNo         String?         @unique
  departmentId    String?         @db.Char(36)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  email           String?
  note            String?
  phone           String?
  sheetCreatedAt  DateTime?
  sheetUpdatedAt  DateTime?
  telegram        String?
  lessons         Lesson[]
  scheduleEntries ScheduleEntry[]
  schedules       Schedule[]
  department      Department?     @relation(fields: [departmentId], references: [id])
  user            User?
  subjects        Subject[]       @relation("SubjectToTeacher")

  @@map("Teacher")
}

model Subject {
  id              String          @id @default(uuid()) @db.Char(36)
  name            String          @unique
  code            String?         @unique
  weeklyLessons   Int             @default(0)
  totalLessons    Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  cohortId        String?         @db.Char(36)
  cohort          Cohort?         @relation(fields: [cohortId], references: [id], onDelete: SetNull)
  parentGroupId   String?         @db.Char(36)
  parentGroup     ParentGroup?    @relation(fields: [parentGroupId], references: [id], onDelete: SetNull)
  lessons         Lesson[]
  scheduleEntries ScheduleEntry[]
  teachers        Teacher[]       @relation("SubjectToTeacher")
  gradeBooks      GradeBook[]

  schedules Schedule[]

  @@index([cohortId])
  @@index([parentGroupId])

  @@map("Subject")
}

model TeachersSheetsSyncState {
  id               String                    @id @default(uuid()) @db.Char(36)
  spreadsheetId    String                    @unique
  lastRunId        String?
  lastStatus       TeachersSheetsSyncStatus?
  lastSyncAt       DateTime?
  lastSuccessAt    DateTime?
  lastError        String?                   @db.LongText
  detectedSubjects Json?
  syncedTeachers   Int                       @default(0)
  spreadsheetRows  Int                       @default(0)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@map("TeachersSheetsSyncState")
}

model TeachersSheetsSyncLog {
  id            String                     @id @default(uuid()) @db.Char(36)
  spreadsheetId String
  runId         String
  level         TeachersSheetsLogLevel     @default(INFO)
  direction     TeachersSheetsLogDirection
  action        String
  sheetTitle    String?
  teacherId     String?                    @db.Char(36)
  message       String                     @db.LongText
  meta          Json?
  createdAt     DateTime                   @default(now())

  @@index([spreadsheetId, createdAt])
  @@index([runId, createdAt])
  @@map("TeachersSheetsSyncLog")
}

model TeachersSheetsWorkerState {
  key             String    @id
  lastHeartbeatAt DateTime?
  lastStartedAt   DateTime?
  lastFinishedAt  DateTime?
  lastError       String?   @db.LongText
  isRunning       Boolean   @default(false)
  updatedAt       DateTime  @updatedAt

  @@map("TeachersSheetsWorkerState")
}

model AttendanceSheetsSyncState {
  id              String                      @id @default(uuid()) @db.Char(36)
  spreadsheetId   String                      @unique
  lastRunId       String?
  lastStatus      AttendanceSheetsSyncStatus?
  lastSyncAt      DateTime?
  lastSuccessAt   DateTime?
  lastError       String?
  detectedTabs    Json?
  processedTabs   Int                         @default(0)
  syncedLessons   Int                         @default(0)
  syncedRecords   Int                         @default(0)
  rosterAdded     Int                         @default(0)
  rosterUpdated   Int                         @default(0)
  spreadsheetRows Int                         @default(0)
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  @@map("AttendanceSheetsSyncState")
}

model AttendanceSheetsSyncLog {
  id            String                      @id @default(uuid()) @db.Char(36)
  spreadsheetId String
  runId         String
  level         AttendanceSheetsLogLevel    @default(INFO)
  direction     AttendanceSheetsLogDirection
  action        String
  sheetTitle    String?
  groupId       String?                     @db.Char(36)
  subjectId     String?                     @db.Char(36)
  lessonId      String?                     @db.Char(36)
  studentId     String?                     @db.Char(36)
  message       String
  meta          Json?
  createdAt     DateTime                    @default(now())

  @@index([spreadsheetId, createdAt])
  @@index([runId, createdAt])
  @@map("AttendanceSheetsSyncLog")
}

model AttendanceSheetsWorkerState {
  key             String    @id
  lastHeartbeatAt DateTime?
  lastStartedAt   DateTime?
  lastFinishedAt  DateTime?
  lastError       String?
  isRunning       Boolean   @default(false)
  updatedAt       DateTime  @updatedAt

  @@map("AttendanceSheetsWorkerState")
}

model Lesson {
  id         String       @id @default(uuid()) @db.Char(36)
  startsAt   DateTime
  endsAt     DateTime
  room       String?
  groupId    String       @db.Char(36)
  teacherId  String       @db.Char(36)
  subjectId  String       @db.Char(36)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  attendance Attendance[]
  group      Group        @relation(fields: [groupId], references: [id])
  subject    Subject      @relation(fields: [subjectId], references: [id])
  teacher    Teacher      @relation(fields: [teacherId], references: [id])

  @@map("Lesson")
}

model CalendarDay {
  id        String   @id @default(uuid()) @db.Char(36)
  date      DateTime @db.Date
  weekday   Weekday
  month     Int
  year      Int
  createdAt DateTime @default(now())

  schedules Schedule[]

  @@unique([date])
  @@map("CalendarDay")
}

model Schedule {
  id            String   @id @default(uuid()) @db.Char(36)
  calendarDayId String   @db.Char(36)
  timeSlotId    String   @db.Char(36)
  groupId       String   @db.Char(36)
  teacherId     String   @db.Char(36)
  subjectId     String   @db.Char(36)
  roomId        String?  @db.Char(36)
  note          String?
  createdAt     DateTime @default(now())

  calendarDay CalendarDay @relation(fields: [calendarDayId], references: [id], onDelete: Cascade)
  timeSlot    TimeSlot    @relation(fields: [timeSlotId], references: [id])
  group       Group       @relation(fields: [groupId], references: [id])
  teacher     Teacher     @relation(fields: [teacherId], references: [id])
  subject     Subject     @relation(fields: [subjectId], references: [id])
  room        Room?       @relation(fields: [roomId], references: [id])

  @@unique([teacherId, calendarDayId, timeSlotId], map: "teacher_schedule_conflict")
  @@unique([groupId, calendarDayId, timeSlotId], map: "group_schedule_conflict")
  @@unique([roomId, calendarDayId, timeSlotId], map: "room_schedule_conflict")
  @@map("Schedule")
}

model ScheduleEntry {
  id            String    @id @default(uuid()) @db.Char(36)
  weekday       Weekday
  groupId       String    @db.Char(36)
  teacherId     String    @db.Char(36)
  subjectId     String    @db.Char(36)
  timeSlotId    String    @db.Char(36)
  roomId        String?   @db.Char(36)
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  group         Group     @relation(fields: [groupId], references: [id])
  room          Room?     @relation(fields: [roomId], references: [id])
  subject       Subject   @relation(fields: [subjectId], references: [id])
  teacher       Teacher   @relation(fields: [teacherId], references: [id])
  timeSlot      TimeSlot  @relation(fields: [timeSlotId], references: [id])

  @@unique([groupId, weekday, timeSlotId])
  @@unique([teacherId, weekday, timeSlotId])
  @@map("ScheduleEntry")
}

model Attendance {
  id        String           @id @default(uuid()) @db.Char(36)
  status    AttendanceStatus
  lessonId  String           @db.Char(36)
  studentId String           @db.Char(36)
  notedAt   DateTime         @default(now())
  lesson    Lesson           @relation(fields: [lessonId], references: [id])
  student   Student          @relation(fields: [studentId], references: [id])

  @@unique([lessonId, studentId])
  @@map("Attendance")
}

model User {
  id                String           @id @default(uuid()) @db.Char(36)
  email             String           @unique
  passwordHash      String?
  role              Role
  lastLoginAt       DateTime?
  credentialsSentAt DateTime?
  studentId         String?          @unique @db.Char(36)
  teacherId         String?          @unique @db.Char(36)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  chats             Chat[]
  chatSessions      ChatSession[]
  loginCodes        LoginCode[]
  student           Student?         @relation(fields: [studentId], references: [id])
  teacher           Teacher?         @relation(fields: [teacherId], references: [id])
  invitations       UserInvitation[]
  profile           UserProfile?
  aiUsageLogs       AiUsageLog[]

  @@map("User")
}

model Permission {
  id   String @id @default(uuid()) @db.Char(36)
  name String @unique

  rolePermissions RolePermission[]

  @@map("Permission")
}

model RolePermission {
  id         String @id @default(uuid()) @db.Char(36)
  role       Role
  permission String

  permissionRef Permission @relation(fields: [permission], references: [name], onDelete: Cascade)

  @@unique([role, permission])
  @@index([role])
  @@index([permission])
  @@map("RolePermission")
}

model ChatSession {
  id        String   @id @default(uuid()) @db.Char(36)
  userId    String   @db.Char(36)
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chats     Chat[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@map("ChatSession")
}

model Chat {
  id        String      @id @default(uuid()) @db.Char(36)
  userId    String      @db.Char(36)
  sessionId String      @db.Char(36)
  message   String
  sender    ChatSender
  timestamp DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
  @@index([sessionId, timestamp])
  @@map("Chat")
}

model StudentsSheetsSyncState {
  id              String                    @id @default(uuid()) @db.Char(36)
  spreadsheetId   String                    @unique
  lastStatus      StudentsSheetsSyncStatus?
  lastSyncAt      DateTime?
  lastSuccessAt   DateTime?
  lastError       String?
  detectedGroups  Json?
  syncedStudents  Int                       @default(0)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  lastRunId       String?
  spreadsheetRows Int                       @default(0)

  @@map("StudentsSheetsSyncState")
}

model StudentsSheetsRowState {
  id            String    @id @default(uuid()) @db.Char(36)
  spreadsheetId String
  sheetTitle    String
  studentId     String    @db.Char(36)
  rowNumber     Int
  rowHash       String
  lastSeenAt    DateTime  @default(now())
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([spreadsheetId, sheetTitle, studentId])
  @@index([spreadsheetId, sheetTitle])
  @@index([studentId])
  @@map("StudentsSheetsRowState")
}

model StudentsSheetsOutboxEvent {
  id               String                     @id @default(uuid()) @db.Char(36)
  spreadsheetId    String
  studentId        String                     @db.Char(36)
  type             StudentsSheetsOutboxType
  targetSheetTitle String?
  payload          Json?
  status           StudentsSheetsOutboxStatus @default(PENDING)
  attempts         Int                        @default(0)
  nextAttemptAt    DateTime                   @default(now())
  lastError        String?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  @@unique([spreadsheetId, studentId])
  @@index([status, nextAttemptAt])
  @@map("StudentsSheetsOutboxEvent")
}

model StudentsSheetsSyncLog {
  id            String                     @id @default(uuid()) @db.Char(36)
  spreadsheetId String
  runId         String
  level         StudentsSheetsLogLevel     @default(INFO)
  direction     StudentsSheetsLogDirection
  action        String
  sheetTitle    String?
  studentId     String?                    @db.Char(36)
  message       String
  meta          Json?
  createdAt     DateTime                   @default(now())

  @@index([spreadsheetId, createdAt])
  @@index([runId, createdAt])
  @@map("StudentsSheetsSyncLog")
}

model StudentsSheetsWorkerState {
  key             String    @id
  lastHeartbeatAt DateTime?
  lastStartedAt   DateTime?
  lastFinishedAt  DateTime?
  lastError       String?
  isRunning       Boolean   @default(false)
  updatedAt       DateTime  @updatedAt

  @@map("StudentsSheetsWorkerState")
}

model UserProfile {
  id          String   @id @default(uuid()) @db.Char(36)
  userId      String   @unique @db.Char(36)
  interests   Json?
  preferences Json?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("UserProfile")
}

model UserInvitation {
  id        String    @id @default(uuid()) @db.Char(36)
  userId    String    @db.Char(36)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("UserInvitation")
}

model AiModel {
  id               String     @id @default(uuid()) @db.Char(36)
  provider         String
  model            String
  displayName      String
  modality         AiModality @default(CHAT)
  isEnabled        Boolean    @default(true)
  enabledForUsers  Boolean    @default(false)
  enabledForAdmins Boolean    @default(true)
  sortOrder        Int        @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  defaultUserChatSettings  AiSettings[] @relation("DefaultUserChatModel")
  defaultAdminChatSettings AiSettings[] @relation("DefaultAdminChatModel")

  @@unique([provider, model])
  @@index([provider, modality, isEnabled, enabledForUsers, sortOrder])
  @@map("AiModel")
}

// Persisted AI admin settings (singleton row).
model AiSettings {
  key                   String   @id
  isEnabled             Boolean  @default(true)
  systemPrompt          String   @db.Text
  toolPlannerPrompt     String   @db.Text
  defaultUserChatModelId  String? @db.Char(36)
  defaultAdminChatModelId String? @db.Char(36)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  defaultUserChatModel  AiModel? @relation("DefaultUserChatModel", fields: [defaultUserChatModelId], references: [id])
  defaultAdminChatModel AiModel? @relation("DefaultAdminChatModel", fields: [defaultAdminChatModelId], references: [id])

  @@map("AiSettings")
}

// Enable/disable tools globally and per-role.
model AiToolConfig {
  name              String   @id
  isEnabled         Boolean  @default(true)
  enabledForStudents Boolean @default(true)
  enabledForTeachers Boolean @default(true)
  enabledForAdmins   Boolean @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("AiToolConfig")
}

// Persisted Google Sheets configuration (singleton row).
// Allows admins to set Spreadsheet IDs from the UI (instead of env-only).
model SheetsSettings {
  key String @id

  studentsSpreadsheetId   String?
  teachersSpreadsheetId   String?
  attendanceSpreadsheetId String?
  gradesSpreadsheetId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("SheetsSettings")
}

// Audit log for AI requests (admin-visible).
model AiUsageLog {
  id               String   @id @default(uuid()) @db.Char(36)
  userId           String?  @db.Char(36)
  role             Role?
  requestId        String?
  provider         String?
  model            String?
  toolName         String?
  toolArgs         Json?
  userMessage      String   @db.LongText
  assistantMessage String?  @db.LongText
  status           String
  error            String?  @db.LongText
  ms               Int?
  meta             Json?
  createdAt        DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("AiUsageLog")
}

// Grades persisted from the Grades spreadsheet (GROUP_SUBJECT tabs).
model GradeBook {
  id              String     @id @default(uuid()) @db.Char(36)
  groupId         String     @db.Char(36)
  subjectId       String     @db.Char(36)
  assignmentCount Int        @default(0)
  source          String     @default("GRADES_SHEETS")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  subject  Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  records  GradeRecord[]

  @@unique([groupId, subjectId])
  @@index([groupId, updatedAt])
  @@map("GradeBook")
}

model GradeRecord {
  id            String   @id @default(uuid()) @db.Char(36)
  gradeBookId   String   @db.Char(36)
  studentId     String   @db.Char(36)
  assignmentIndex Int
  rawValue      String?
  score         Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  gradeBook GradeBook @relation(fields: [gradeBookId], references: [id], onDelete: Cascade)
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([gradeBookId, studentId, assignmentIndex])
  @@index([studentId, updatedAt])
  @@map("GradeRecord")
}

model LoginCode {
  id        String    @id @default(uuid()) @db.Char(36)
  userId    String    @db.Char(36)
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("LoginCode")
}

// --- University public info (admissions / marketing / receptionist data) ---

model University {
  id          String   @id @default(uuid()) @db.Char(36)
  name        String   @unique @db.VarChar(180)
  description String?  @db.LongText
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  diplomas    UniversityDiploma[]
  departments UniversityDepartment[]
  fees        UniversityFee[]
  facilities  UniversityFacility[]
  announcements ReceptionistAnnouncement[]

  @@map("universities")
}

model UniversityDiploma {
  id           String   @id @default(uuid()) @db.Char(36)
  universityId String   @db.Char(36)
  name         String   @db.VarChar(180)
  description  String?  @db.LongText
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@unique([universityId, name])
  @@index([universityId])
  @@map("diplomas")
}

// NOTE: Named `UniversityDepartment` to avoid colliding with the existing `Department` model/table.
model UniversityDepartment {
  id           String   @id @default(uuid()) @db.Char(36)
  universityId String   @db.Char(36)
  name         String   @db.VarChar(180)
  description  String?  @db.LongText
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  specialties UniversitySpecialty[]

  @@unique([universityId, name])
  @@index([universityId])
  @@map("university_departments")
}

model UniversitySpecialty {
  id           String   @id @default(uuid()) @db.Char(36)
  departmentId String   @db.Char(36)
  name         String   @db.VarChar(180)
  description  String?  @db.LongText
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department UniversityDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  fees       UniversityFee[]

  @@unique([departmentId, name])
  @@index([departmentId])
  @@map("specialties")
}

model UniversityFee {
  id           String   @id @default(uuid()) @db.Char(36)
  universityId String   @db.Char(36)
  specialtyId  String?  @db.Char(36)
  title        String   @db.VarChar(180)
  amount       Decimal? @db.Decimal(12, 2)
  currency     String   @default("UZS") @db.VarChar(8)
  description  String?  @db.LongText
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  specialty  UniversitySpecialty? @relation(fields: [specialtyId], references: [id], onDelete: SetNull)

  @@index([universityId])
  @@index([specialtyId])
  @@map("fees")
}

model UniversityFacility {
  id           String   @id @default(uuid()) @db.Char(36)
  universityId String   @db.Char(36)
  name         String   @db.VarChar(180)
  description  String?  @db.LongText
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@unique([universityId, name])
  @@index([universityId])
  @@map("facilities")
}

// --- AI Receptionist (LEIA) ---

model ReceptionistKnowledgeBaseEntry {
  id        String              @id @default(uuid()) @db.Char(36)
  title     String              @db.VarChar(255)
  content   String              @db.LongText
  category  String              @db.VarChar(64)
  language  ReceptionistLanguage
  tags      Json?
  priority  Int                 @default(0)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([category, language, priority])
  @@index([language, priority])
  @@map("knowledge_base")
}

model ReceptionistLocation {
  id          String                 @id @default(uuid()) @db.Char(36)
  name        String                 @db.VarChar(140)
  building    String?                @db.VarChar(140)
  floor       String?                @db.VarChar(40)
  description String?                @db.LongText
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  directionsFrom ReceptionistDirection[] @relation("ReceptionistDirectionFrom")
  directionsTo   ReceptionistDirection[] @relation("ReceptionistDirectionTo")

  @@unique([name])
  @@index([building])
  @@map("locations")
}

model ReceptionistDirection {
  id             String               @id @default(uuid()) @db.Char(36)
  fromLocationId String               @db.Char(36)
  toLocationId   String               @db.Char(36)
  instructions   String               @db.LongText
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  fromLocation ReceptionistLocation @relation("ReceptionistDirectionFrom", fields: [fromLocationId], references: [id], onDelete: Cascade)
  toLocation   ReceptionistLocation @relation("ReceptionistDirectionTo", fields: [toLocationId], references: [id], onDelete: Cascade)

  @@unique([fromLocationId, toLocationId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@map("directions")
}

// Singleton-ish settings row; use `key = "default"`.
model ReceptionistAiAvatar {
  id          String                 @id @default(uuid()) @db.Char(36)
  key         String                 @unique @db.VarChar(64)
  name        String                 @default("LEIA") @db.VarChar(80)
  modelUrl    String?                @db.VarChar(512)
  voice       String?                @db.VarChar(128)
  language    ReceptionistLanguage   @default(UZ)
  inputLanguage  ReceptionistLanguage @default(UZ)
  outputLanguage ReceptionistLanguage @default(UZ)
  personality ReceptionistPersonality @default(FRIENDLY)

  // --- Personality / Response generation ---
  systemPrompt      String? @db.LongText
  responseStyle     String? @db.LongText
  maxResponseTokens Int     @default(900)
  temperature       Float   @default(0.4)

  // --- Knowledge control ---
  autoRefreshKnowledge Boolean @default(true)
  allowedTopics        Json?
  blockedTopics        Json?

  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@map("ai_avatar")
}

model ReceptionistAnnouncement {
  id             String               @id @default(uuid()) @db.Char(36)
  universityId    String?              @db.Char(36)
  title          String               @db.VarChar(200)
  content        String               @db.LongText
  targetAudience String               @db.VarChar(80)
  language       ReceptionistLanguage?
  isActive       Boolean              @default(true)
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  university University? @relation(fields: [universityId], references: [id], onDelete: SetNull)

  @@index([universityId])
  @@index([isActive, startsAt, endsAt, createdAt])
  @@map("announcements")
}

model ReceptionistConversation {
  id           String               @id @default(uuid()) @db.Char(36)
  language     ReceptionistLanguage @default(UZ)
  lastActiveAt DateTime             @default(now())
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  messages ReceptionistMessage[]

  @@index([updatedAt])
  @@map("conversations")
}

model ReceptionistMessage {
  id             String                    @id @default(uuid()) @db.Char(36)
  conversationId String                    @db.Char(36)
  sender         ReceptionistMessageSender
  modality       ReceptionistMessageModality @default(TEXT)
  text           String                    @db.LongText
  meta           Json?
  createdAt      DateTime                  @default(now())

  conversation ReceptionistConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

