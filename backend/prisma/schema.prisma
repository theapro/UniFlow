generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Department {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  teachers  Teacher[]

  @@map("Department")
}

model Room {
  id              String          @id @default(uuid()) @db.Uuid
  name            String          @unique
  capacity        Int?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  scheduleEntries ScheduleEntry[]

  @@map("Room")
}

model TimeSlot {
  id              String          @id @default(uuid()) @db.Uuid
  order           Int             @unique
  startTime       String
  endTime         String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  scheduleEntries ScheduleEntry[]

  @@map("TimeSlot")
}

model Group {
  id              String          @id @default(uuid()) @db.Uuid
  name            String          @unique
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  cohortId        String?         @db.Uuid
  cohort          Cohort?         @relation(fields: [cohortId], references: [id])
  lessons         Lesson[]
  scheduleEntries ScheduleEntry[]
  students        Student[]

  @@index([cohortId])
  @@map("Group")
}

model Cohort {
  id        String   @id @default(uuid()) @db.Uuid
  year      Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  groups    Group[]

  @@map("Cohort")
}

model Student {
  id            String        @id @default(uuid()) @db.Uuid
  fullName      String
  groupId       String?       @db.Uuid
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @default(now())
  email         String?
  note          String?
  parentIds     String[]      @default([])
  phone         String?
  status        StudentStatus @default(ACTIVE)
  studentNumber String?       @unique
  teacherIds    String[]      @default([])
  cohort        String?
  groupName     String?       @map("group")
  attendance    Attendance[]
  group         Group?        @relation(fields: [groupId], references: [id])
  user          User?

  @@map("Student")
}

model StudentsSheetsConflict {
  id            String                            @id @default(uuid()) @db.Uuid
  spreadsheetId String
  sheetTitle    String?
  rowNumber     Int?
  studentId     String?                           @db.Uuid
  status        StudentsSheetsConflictStatus      @default(OPEN)
  resolution    StudentsSheetsConflictResolution?
  message       String?
  sheetPayload  Json?
  dbPayload     Json?
  baseHash      String?
  detectedAt    DateTime                          @default(now())
  resolvedAt    DateTime?
  createdAt     DateTime                          @default(now())
  updatedAt     DateTime                          @updatedAt

  @@unique([spreadsheetId, studentId])
  @@index([spreadsheetId, status, detectedAt])
  @@index([studentId])
  @@map("StudentsSheetsConflict")
}

model Teacher {
  id              String          @id @default(uuid()) @db.Uuid
  fullName        String
  staffNo         String?         @unique
  departmentId    String?         @db.Uuid
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  email           String?
  note            String?
  phone           String?
  sheetCreatedAt  DateTime?
  sheetUpdatedAt  DateTime?
  telegram        String?
  lessons         Lesson[]
  scheduleEntries ScheduleEntry[]
  department      Department?     @relation(fields: [departmentId], references: [id])
  user            User?
  subjects        Subject[]       @relation("SubjectToTeacher")

  @@map("Teacher")
}

model Subject {
  id              String          @id @default(uuid()) @db.Uuid
  name            String          @unique
  code            String?         @unique
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  lessons         Lesson[]
  scheduleEntries ScheduleEntry[]
  teachers        Teacher[]       @relation("SubjectToTeacher")

  @@map("Subject")
}

model TeachersSheetsSyncState {
  id               String                    @id @default(uuid()) @db.Uuid
  spreadsheetId    String                    @unique
  lastRunId        String?
  lastStatus       TeachersSheetsSyncStatus?
  lastSyncAt       DateTime?
  lastSuccessAt    DateTime?
  lastError        String?
  detectedSubjects String[]                  @default([])
  syncedTeachers   Int                       @default(0)
  spreadsheetRows  Int                       @default(0)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@map("TeachersSheetsSyncState")
}

model TeachersSheetsSyncLog {
  id            String                     @id @default(uuid()) @db.Uuid
  spreadsheetId String
  runId         String
  level         TeachersSheetsLogLevel     @default(INFO)
  direction     TeachersSheetsLogDirection
  action        String
  sheetTitle    String?
  teacherId     String?                    @db.Uuid
  message       String
  meta          Json?
  createdAt     DateTime                   @default(now())

  @@index([spreadsheetId, createdAt])
  @@index([runId, createdAt])
  @@map("TeachersSheetsSyncLog")
}

model TeachersSheetsWorkerState {
  key             String    @id
  lastHeartbeatAt DateTime?
  lastStartedAt   DateTime?
  lastFinishedAt  DateTime?
  lastError       String?
  isRunning       Boolean   @default(false)
  updatedAt       DateTime  @updatedAt

  @@map("TeachersSheetsWorkerState")
}

model AttendanceSheetsSyncState {
  id              String                      @id @default(uuid()) @db.Uuid
  spreadsheetId   String                      @unique
  lastRunId       String?
  lastStatus      AttendanceSheetsSyncStatus?
  lastSyncAt      DateTime?
  lastSuccessAt   DateTime?
  lastError       String?
  detectedTabs    String[]                    @default([])
  processedTabs   Int                         @default(0)
  syncedLessons   Int                         @default(0)
  syncedRecords   Int                         @default(0)
  rosterAdded     Int                         @default(0)
  rosterUpdated   Int                         @default(0)
  spreadsheetRows Int                         @default(0)
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  @@map("AttendanceSheetsSyncState")
}

model AttendanceSheetsSyncLog {
  id            String                      @id @default(uuid()) @db.Uuid
  spreadsheetId String
  runId         String
  level         AttendanceSheetsLogLevel    @default(INFO)
  direction     AttendanceSheetsLogDirection
  action        String
  sheetTitle    String?
  groupId       String?                     @db.Uuid
  subjectId     String?                     @db.Uuid
  lessonId      String?                     @db.Uuid
  studentId     String?                     @db.Uuid
  message       String
  meta          Json?
  createdAt     DateTime                    @default(now())

  @@index([spreadsheetId, createdAt])
  @@index([runId, createdAt])
  @@map("AttendanceSheetsSyncLog")
}

model AttendanceSheetsWorkerState {
  key             String    @id
  lastHeartbeatAt DateTime?
  lastStartedAt   DateTime?
  lastFinishedAt  DateTime?
  lastError       String?
  isRunning       Boolean   @default(false)
  updatedAt       DateTime  @updatedAt

  @@map("AttendanceSheetsWorkerState")
}

model Lesson {
  id         String       @id @default(uuid()) @db.Uuid
  startsAt   DateTime
  endsAt     DateTime
  room       String?
  groupId    String       @db.Uuid
  teacherId  String       @db.Uuid
  subjectId  String       @db.Uuid
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  attendance Attendance[]
  group      Group        @relation(fields: [groupId], references: [id])
  subject    Subject      @relation(fields: [subjectId], references: [id])
  teacher    Teacher      @relation(fields: [teacherId], references: [id])

  @@map("Lesson")
}

model ScheduleEntry {
  id            String    @id @default(uuid()) @db.Uuid
  weekday       Weekday
  groupId       String    @db.Uuid
  teacherId     String    @db.Uuid
  subjectId     String    @db.Uuid
  timeSlotId    String    @db.Uuid
  roomId        String?   @db.Uuid
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  group         Group     @relation(fields: [groupId], references: [id])
  room          Room?     @relation(fields: [roomId], references: [id])
  subject       Subject   @relation(fields: [subjectId], references: [id])
  teacher       Teacher   @relation(fields: [teacherId], references: [id])
  timeSlot      TimeSlot  @relation(fields: [timeSlotId], references: [id])

  @@unique([groupId, weekday, timeSlotId])
  @@unique([teacherId, weekday, timeSlotId])
  @@map("ScheduleEntry")
}

model Attendance {
  id        String           @id @default(uuid()) @db.Uuid
  status    AttendanceStatus
  lessonId  String           @db.Uuid
  studentId String           @db.Uuid
  notedAt   DateTime         @default(now())
  lesson    Lesson           @relation(fields: [lessonId], references: [id])
  student   Student          @relation(fields: [studentId], references: [id])

  @@unique([lessonId, studentId])
  @@map("Attendance")
}

model User {
  id                String           @id @default(uuid()) @db.Uuid
  email             String           @unique
  passwordHash      String?
  role              UserRole
  lastLoginAt       DateTime?
  credentialsSentAt DateTime?
  studentId         String?          @unique @db.Uuid
  teacherId         String?          @unique @db.Uuid
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  chats             Chat[]
  chatSessions      ChatSession[]
  loginCodes        LoginCode[]
  student           Student?         @relation(fields: [studentId], references: [id])
  teacher           Teacher?         @relation(fields: [teacherId], references: [id])
  invitations       UserInvitation[]
  profile           UserProfile?

  @@map("User")
}

model ChatSession {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chats     Chat[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@map("ChatSession")
}

model Chat {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String      @db.Uuid
  sessionId String      @db.Uuid
  message   String
  sender    ChatSender
  timestamp DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
  @@index([sessionId, timestamp])
  @@map("Chat")
}

model StudentsSheetsSyncState {
  id              String                    @id @default(uuid()) @db.Uuid
  spreadsheetId   String                    @unique
  lastStatus      StudentsSheetsSyncStatus?
  lastSyncAt      DateTime?
  lastSuccessAt   DateTime?
  lastError       String?
  detectedGroups  String[]                  @default([])
  syncedStudents  Int                       @default(0)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  lastRunId       String?
  spreadsheetRows Int                       @default(0)

  @@map("StudentsSheetsSyncState")
}

model StudentsSheetsRowState {
  id            String    @id @default(uuid()) @db.Uuid
  spreadsheetId String
  sheetTitle    String
  studentId     String    @db.Uuid
  rowNumber     Int
  rowHash       String
  lastSeenAt    DateTime  @default(now())
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([spreadsheetId, sheetTitle, studentId])
  @@index([spreadsheetId, sheetTitle])
  @@index([studentId])
  @@map("StudentsSheetsRowState")
}

model StudentsSheetsOutboxEvent {
  id               String                     @id @default(uuid()) @db.Uuid
  spreadsheetId    String
  studentId        String                     @db.Uuid
  type             StudentsSheetsOutboxType
  targetSheetTitle String?
  payload          Json?
  status           StudentsSheetsOutboxStatus @default(PENDING)
  attempts         Int                        @default(0)
  nextAttemptAt    DateTime                   @default(now())
  lastError        String?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  @@unique([spreadsheetId, studentId])
  @@index([status, nextAttemptAt])
  @@map("StudentsSheetsOutboxEvent")
}

model StudentsSheetsSyncLog {
  id            String                     @id @default(uuid()) @db.Uuid
  spreadsheetId String
  runId         String
  level         StudentsSheetsLogLevel     @default(INFO)
  direction     StudentsSheetsLogDirection
  action        String
  sheetTitle    String?
  studentId     String?                    @db.Uuid
  message       String
  meta          Json?
  createdAt     DateTime                   @default(now())

  @@index([spreadsheetId, createdAt])
  @@index([runId, createdAt])
  @@map("StudentsSheetsSyncLog")
}

model StudentsSheetsWorkerState {
  key             String    @id
  lastHeartbeatAt DateTime?
  lastStartedAt   DateTime?
  lastFinishedAt  DateTime?
  lastError       String?
  isRunning       Boolean   @default(false)
  updatedAt       DateTime  @updatedAt

  @@map("StudentsSheetsWorkerState")
}

model UserProfile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @db.Uuid
  interests   Json?
  preferences Json?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("UserProfile")
}

model UserInvitation {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("UserInvitation")
}

model AiModel {
  id               String     @id @default(uuid()) @db.Uuid
  provider         String
  model            String
  displayName      String
  modality         AiModality @default(CHAT)
  isEnabled        Boolean    @default(true)
  enabledForUsers  Boolean    @default(false)
  enabledForAdmins Boolean    @default(true)
  sortOrder        Int        @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([provider, model])
  @@index([provider, modality, isEnabled, enabledForUsers, sortOrder])
  @@map("AiModel")
}

model LoginCode {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("LoginCode")
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  DROPPED
}

enum StudentsSheetsConflictStatus {
  OPEN
  RESOLVED
}

enum StudentsSheetsConflictResolution {
  KEEP_SHEET
  KEEP_DB
  MERGE
}

enum TeachersSheetsSyncStatus {
  SUCCESS
  FAILED
}

enum TeachersSheetsLogLevel {
  INFO
  WARN
  ERROR
}

enum TeachersSheetsLogDirection {
  SHEETS_TO_DB
}

enum StudentsSheetsSyncStatus {
  SUCCESS
  FAILED
}

enum StudentsSheetsOutboxType {
  UPSERT
  DELETE
}

enum StudentsSheetsOutboxStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum StudentsSheetsLogLevel {
  INFO
  WARN
  ERROR
}

enum StudentsSheetsLogDirection {
  SHEETS_TO_DB
  DB_TO_SHEETS
  WORKER
}

enum AttendanceSheetsSyncStatus {
  SUCCESS
  FAILED
}

enum AttendanceSheetsLogLevel {
  INFO
  WARN
  ERROR
}

enum AttendanceSheetsLogDirection {
  SHEETS_TO_DB
  DB_TO_SHEETS
  WORKER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED

  @@map("AttendanceStatus")
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN

  @@map("UserRole")
}

enum ChatSender {
  USER
  ASSISTANT
  SYSTEM

  @@map("ChatSender")
}

enum AiModality {
  CHAT
  VISION
  STT
  TTS
  MODERATION

  @@map("AiModality")
}

enum Weekday {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN

  @@map("Weekday")
}
